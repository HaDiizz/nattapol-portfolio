  svg: string,
  bgClass: string = 'dark:bg-white/90 p-[2px] rounded-sm'
) => {
  return `<div class="${className} ${bgClass} flex items-center justify-center">${svg}</div>`;
};
const wrapNormal = (svg: string) => {
  return `<div class="${className} flex items-center justify-center">${svg}</div>`;
};

