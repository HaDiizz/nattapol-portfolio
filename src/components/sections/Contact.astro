---
import { ExternalLink, Github, Mail } from 'lucide-astro';
---

<section id="contact" class="py-32 border-t border-[var(--border)] flex flex-col items-center justify-center text-center">
  <h2 class="section-heading text-4xl md:text-5xl font-bold tracking-tight mb-8">
    Let's build something together.
  </h2>

  <a href="mailto:nattapol.dev@gmail.com" class="group flex items-center gap-2 text-xl md:text-2xl font-medium text-[var(--text)] hover:text-[var(--accent)] transition-colors mb-12">
    nattapol.dev@gmail.com
    <ExternalLink class="w-5 h-5 text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors" />
  </a>

  <div class="flex items-center gap-6 mb-16">
    <a href="https://github.com/HaDiizz" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-[var(--accent)] transition-all">
      <Github class="w-6 h-6" />
      <span class="sr-only">GitHub</span>
    </a>
    <a href="mailto:nattapol.dev@gmail.com" class="p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-[var(--accent)] transition-all">
      <Mail class="w-6 h-6" />
      <span class="sr-only">Email</span>
    </a>
  </div>

  <p class="text-[var(--text-muted)] font-medium">
    Hat Yai, Songkhla, Thailand &middot; UTC+7
  </p>
</section>
