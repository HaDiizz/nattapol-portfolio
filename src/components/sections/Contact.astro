---
import { ExternalLink, Github, Mail } from 'lucide-astro';
import { Image } from 'astro:assets';
import lineQrImg from '../../assets/line-qrcode.jpg';
---

<section
  id="contact"
  class="py-32 border-t border-[var(--border)] flex flex-col items-center justify-center text-center"
>
  <h2
    class="section-heading text-4xl md:text-5xl font-bold tracking-tight mb-8"
  >
    Let's build something together.
  </h2>

  <a
    href="mailto:nattapol.dev@gmail.com"
    class="contact-item group flex items-center gap-2 text-xl md:text-2xl font-medium text-[var(--text)] hover:text-[var(--accent)] transition-colors mb-12"
  >
    nattapol.dev@gmail.com
    <ExternalLink
      class="w-5 h-5 text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors"
    />
  </a>

  <div
    class="contact-item flex flex-wrap items-center justify-center gap-6 mb-16"
  >
    <a
      href="https://github.com/HaDiizz"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-black dark:hover:text-white transition-colors relative group"
    >
      <Github class="contact-icon w-6 h-6" />
      <span
        class="absolute -bottom-8 left-1/2 -translate-x-1/2 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity"
        >GitHub</span
      >
    </a>

    <a
      href="https://www.linkedin.com/in/nattapol-sh"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-[#0A66C2] transition-colors relative group"
    >
      <svg
        class="contact-icon w-6 h-6"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid"
        viewBox="0 0 256 256"
        ><path
          d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.907 39.907 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186l-.016 67.013ZM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009-.002-12.157 9.851-22.014 22.008-22.016 12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97v122.16ZM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453"
          fill="#0A66C2"></path></svg
      >
      <span
        class="absolute -bottom-8 left-1/2 -translate-x-1/2 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity"
        >LinkedIn</span
      >
    </a>

    <div class="relative group">
      <a
        href="https://line.me/ti/p/vxDzI1FmEF"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-[#00C300] transition-colors flex items-center justify-center group-hover:text-[#00C300]"
      >
        <svg
          class="contact-icon w-6 h-6"
          fill="#00C300"
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          ><title>LINE</title><path
            d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
          ></path></svg
        >
        <span
          class="absolute -bottom-8 left-1/2 -translate-x-1/2 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity"
          >LINE</span
        >
      </a>
      <!-- QR Code Tooltip -->
      <div
        class="absolute bottom-full left-1/2 -translate-x-1/2 mb-4 w-40 h-40 p-2 bg-white rounded-xl shadow-2xl border border-gray-200 opacity-0 pointer-events-none translate-y-4 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 transition-all duration-300 z-50"
      >
        <Image
          src={lineQrImg}
          alt="LINE QR Code"
          class="w-full h-full object-contain rounded-lg"
        />
        <div
          class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-white border-b border-r border-gray-200 rotate-45"
        >
        </div>
      </div>
    </div>

    <a
      href="mailto:nattapol.dev@gmail.com"
      class="contact-btn p-3 rounded-full border border-[var(--border)] text-[var(--text)] hover:bg-[var(--tag-bg)] hover:text-[#EA4335] transition-colors relative group"
    >
      <svg
        class="contact-icon w-6 h-6"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 49.4 512 399.42"
      >
        <g fill="none" fill-rule="evenodd">
          <g fill-rule="nonzero">
            <path
              fill="#4285f4"
              d="M34.91 448.818h81.454V251L0 163.727V413.91c0 19.287 15.622 34.91 34.91 34.91z"
            ></path>
            <path
              fill="#34a853"
              d="M395.636 448.818h81.455c19.287 0 34.909-15.622 34.909-34.909V163.727L395.636 251z"
            ></path>
            <path
              fill="#fbbc04"
              d="M395.636 99.727V251L512 163.727v-46.545c0-43.142-49.25-67.782-83.782-41.891z"
            ></path>
          </g>
          <path
            fill="#ea4335"
            d="M116.364 251V99.727L256 204.455 395.636 99.727V251L256 355.727z"
          ></path>
          <path
            fill="#c5221f"
            fill-rule="nonzero"
            d="M0 117.182v46.545L116.364 251V99.727L83.782 75.291C49.25 49.4 0 74.04 0 117.18z"
          ></path>
        </g>
      </svg>
      <span
        class="absolute -bottom-8 left-1/2 -translate-x-1/2 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity"
        >Gmail</span
      >
    </a>
  </div>

  <p class="text-[var(--text-muted)] font-medium">
    Hat Yai, Songkhla, Thailand &middot; UTC+7
  </p>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const contactBtns = document.querySelectorAll('.contact-btn');

    contactBtns.forEach((btn) => {
      const icon = btn.querySelector('.contact-icon');
      if (!icon) return;

      // Hint to the browser for performance (from gsap-performance skill)
      gsap.set(icon, { willChange: 'transform' });

      btn.addEventListener('mouseenter', () => {
        // Animate the icon only to avoid hit-area jitter (mouse slipping off)
        gsap.to(icon, {
          y: -4,
          scale: 1.15,
          rotation: 5,
          duration: 0.4,
          ease: 'back.out(1.7)',
          overwrite: true,
        });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(icon, {
          y: 0,
          scale: 1,
          rotation: 0,
          duration: 0.3,
          ease: 'power2.out',
          overwrite: true,
        });
      });
    });
  });
</script>
