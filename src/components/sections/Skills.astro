---
import type { skills } from '../../data/skills';
import SkillIcon from '../ui/SkillIcon.astro';

interface Props {
  groups: typeof skills;
}

const { groups } = Astro.props;
---

<section id="skills" class="py-20 border-t border-[var(--border)]">
  <div class="grid md:grid-cols-12 gap-12 items-start">
    <div class="md:col-span-5 lg:col-span-4">
      <h2 class="section-heading text-3xl font-bold mb-6">Skills</h2>
    </div>

    <div class="md:col-span-7 lg:col-span-8 flex flex-col gap-10">
      {
        Object.entries(groups).map(([category, items]) => (
          <div class="skill-group">
            <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-4">
              {category}
            </h3>
            <div class="flex flex-wrap gap-2.5">
              {items.map((skill) => (
                <span class="skill-tag group cursor-default flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium bg-[var(--tag-bg)] text-[var(--tag-text)] border border-[var(--border)] hover:border-[var(--accent)] hover:text-[var(--text)] transition-colors">
                  <SkillIcon
                    name={skill}
                    class="w-4 h-4 object-contain group-hover:animate-bubble-pop"
                  />
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  @keyframes bubble-pop {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.15);
    }
    100% {
      transform: scale(1);
    }
  }
  .group:hover .group-hover\:animate-bubble-pop {
    animation: bubble-pop 0.6s cubic-bezier(0.68, -0.55, 0.26, 1.55) forwards;
  }
</style>
