---
import { ArrowDownRight, Github, Mail, FileText } from 'lucide-astro';
import { Image } from 'astro:assets';
import profileImg from '../../assets/profile.jpg';
---

<section id="hero" class="pt-32 pb-20 md:pt-40 md:pb-32 flex flex-col items-start min-h-[80vh] justify-center">
  <div class="hero-avatar mb-8">
    <Image 
      src={profileImg} 
      alt="Nattapol Singhad" 
      class="w-24 h-24 md:w-32 md:h-32 rounded-full object-cover border border-[var(--border)] transition-all duration-500"
    />
  </div>

  <h1 class="hero-name text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-4">
    Nattapol Singhad
  </h1>
  
  <h2 class="hero-role text-xl md:text-2xl text-[var(--text-muted)] font-medium mb-8">
    Software Engineer
  </h2>

  <div class="hero-meta text-sm md:text-base text-[var(--text-muted)] mb-10 flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <span class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-green-500"></span>
      Based in Hat Yai, Phuket, Bangkok, Thailand &middot; Open to remote
    </span>
  </div>

  <div class="hero-btns flex flex-wrap items-center gap-4 mb-16">
    <a href="#projects" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--text)] text-[var(--bg)] font-medium hover:opacity-90 transition-opacity">
      View Work
      <ArrowDownRight class="w-4 h-4" />
    </a>
    <a href="/docs/Nattapol_Singhad_Resume_CV.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[var(--border)] hover:bg-[var(--tag-bg)] transition-colors">
      <FileText class="w-4 h-4" />
      Resume
    </a>
    <a href="https://github.com/HaDiizz" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[var(--border)] hover:bg-[var(--tag-bg)] transition-colors">
      <Github class="w-4 h-4" />
      GitHub
    </a>
    <a href="mailto:nattapol.dev@gmail.com" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[var(--border)] hover:bg-[var(--tag-bg)] transition-colors">
      <Mail class="w-4 h-4" />
      Email
    </a>
  </div>

  <div class="hero-stats w-full pt-8 border-t border-[var(--border)] flex flex-wrap justify-center items-center gap-x-8 gap-y-4 text-sm font-medium text-[var(--text-muted)]">
    <span>2y exp</span>
    <span>&middot;</span>
    <span>3 companies</span>
    <span>&middot;</span>
    <span>10+ shipped projects</span>
  </div>
</section>
